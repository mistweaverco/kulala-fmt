{
  "name": "@mistweaverco/kulala-fmt",
  "version": "4.3.4",
  "repository": {
    "type": "git",
    "url": "https://github.com/mistweaverco/kulala-fmt"
  },
  "bin": {
    "kulala-fmt": "dist/cli.cjs"
  },
  "files": [
    "dist/cli.cjs",
    "dist/install-backend.cjs"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsx ./scripts/build.ts",
    "lint": "vp lint",
    "prepare": "vp config && tsx ./scripts/build.ts || true",
    "postinstall": "node dist/install-backend.cjs || true"
  },
  "devDependencies": {
    "@types/js-yaml": "4.0.9",
    "@types/node": "25.9.1",
    "chalk": "5.6.2",
    "colors": "1.4.0",
    "commander": "15.0.0",
    "conventional-changelog": "7.2.0",
    "diff": "9.0.0",
    "eslint-plugin-prettier": "5.5.6",
    "globals": "17.6.0",
    "js-yaml": "4.2.0",
    "lodash": "4.18.1",
    "ohm-js": "17.5.0",
    "picocolors": "1.1.1",
    "prettier": "3.8.4",
    "tsx": "4.22.4",
    "typescript": "5.9.3",
    "vite-plus": "catalog:"
  },
  "packageManager": "pnpm@11.5.2"
}
